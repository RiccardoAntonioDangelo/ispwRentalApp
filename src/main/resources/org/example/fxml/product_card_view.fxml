<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="cardRoot" prefWidth="350.0" spacing="0" styleClass="bg-surface, rounded-lg, border-all" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.view.javafx.componet.ProductCardGC">
    <children>
        <StackPane fx:id="imgPlaceholder" opacity="0.5" prefHeight="180.0" prefWidth="350.0" styleClass="bg-bg, border-bottom" alignment="CENTER" />

        <VBox spacing="12.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <Label fx:id="titleLabel" styleClass="size-18, font-bold, text-hi" wrapText="true" />

                <Label fx:id="subtitleLabel" wrapText="true" />

                <HBox fx:id="badgeContainer" alignment="CENTER_LEFT" spacing="8.0" styleClass="size-12">
                    <children>
                        <Label text="✅" />
                        <Label fx:id="badgeLabel" wrapText="true" />
                    </children>
                </HBox>

                <HBox alignment="BOTTOM_LEFT">
                    <children>
                        <VBox fx:id="priceBox">
                            <children>
                                <Label fx:id="fromLabel" styleClass="size-11, text-lo" />
                                <Label fx:id="priceValueLabel" styleClass="size-16, font-bold, text-hi" />
                            </children>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS" />

                        <Button fx:id="detailsBtn" mnemonicParsing="false" onAction="#onDetailsAction" prefHeight="35.0" styleClass="btn-primary" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</VBox>