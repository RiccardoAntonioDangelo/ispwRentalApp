<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="TOP_CENTER" spacing="0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
       styleClass="bg-bg">
    <padding>
        <Insets top="80.0" bottom="80.0"/>
    </padding>

    <VBox fx:id="successCard" alignment="CENTER" spacing="30.0" maxWidth="600.0" styleClass="bg-surface, rounded-lg, border-all">
        <padding>
            <Insets top="50.0" right="50.0" bottom="50.0" left="50.0"/>
        </padding>

        <!-- Success Icon -->
        <StackPane prefWidth="80.0" prefHeight="80.0" styleClass="bg-primary-soft, rounded-full">
            <Label text="✓" styleClass="size-32, text-primary, font-bold"/>
        </StackPane>

        <!-- Title & Message -->
        <VBox alignment="CENTER" spacing="10.0">
            <Label fx:id="titleLabel" styleClass="size-24, font-bold, text-hi"/>
            <Label fx:id="messageLabel" styleClass="size-14, text-lo" textAlignment="CENTER" wrapText="true"/>
        </VBox>

        <!-- Request Badge -->
        <HBox alignment="CENTER" spacing="10.0" styleClass="bg-bg, rounded-md, border-all">
            <padding><Insets top="10.0" right="20.0" bottom="10.0" left="20.0"/></padding>
            <Label fx:id="requestLabel" styleClass="size-13, text-lo"/>
            <Label fx:id="requestValueLabel" styleClass="size-14, font-bold, text-hi"/>
        </HBox>

        <!-- Action Button -->
        <Button fx:id="homeBtn" onAction="#handleHome" prefWidth="400.0" prefHeight="50.0" styleClass="btn-primary"/>
    </VBox>
</VBox>
